{
    "version": "0.2.0",
    "configurations": [
        {
            // debug the aspnet backend and open the listening url when ready
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            // update this path if the target framework folder name changes
            "program": "${workspaceFolder}/backend/413mission10hw/413mission10hw/bin/Debug/net10.0/413mission10hw.dll",
            "args": [],
            "cwd": "${workspaceFolder}/backend/413mission10hw/413mission10hw",
            "stopAtEntry": false,
            // open a browser when the host prints the listening line
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            // attach to a dotnet process already running
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
{
    "version": "2.0.0",
    "tasks": [
        {
            // compiles the backend project for launch and ci
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/backend/413mission10hw/413mission10hw/413mission10hw.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            // produces a release folder for deployment
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/backend/413mission10hw/413mission10hw/413mission10hw.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            // rebuild and restart the api when source files change
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/backend/413mission10hw/413mission10hw/413mission10hw.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}